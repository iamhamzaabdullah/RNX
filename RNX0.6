   "source": [
    "ptx_preds={}\n",
    "\n",
    "def _split(L,maxL,overlap):\n",
    "    if L<=maxL: return [(0,L)]\n",
    "    chunks=[]; step=maxL-overlap; pos=0\n",
    "    while pos<L:\n",
    "        e=min(pos+maxL,L); chunks.append((pos,e))\n",
    "        if e==L: break\n",
    "        pos+=step\n",
    "    return chunks\n",
    "\n",
    "def _pb(v): return 'true' if str(v).strip().lower() in {'1','true','t','yes'} else 'false'\n",
    "USE_MSA=_pb(os.environ.get('USE_MSA','false'))\n",
    "USE_TMPL=_pb(os.environ.get('USE_TEMPLATE','false'))\n",
    "USE_RNA_MSA=_pb(os.environ.get('USE_RNA_MSA','true'))\n",
    "\n",
    "if ptx_queue and USE_PROTENIX and PTX_DIR:\n",
    "    print(f\"\\n{'='*60}\")\n",
    "    print(f'PHASE 2 — RNAPro Protenix+RNet2 for {len(ptx_queue)} targets')\n",
    "    print(f'  USE_RNA_MSA={USE_RNA_MSA}  CHUNK_OVERLAP={CHUNK_OVERLAP}')\n",
    "    print(f\"{'='*60}\")\n",
    "    os.environ['PROTENIX_ROOT_DIR']=PTX_DIR\n",
    "    sys.path.insert(0,PTX_DIR)\n",
    "\n",
    "    from configs.configs_base      import configs as cfg_base\n",
    "    from configs.configs_data      import data_configs\n",
    "    from configs.configs_inference import inference_configs\n",
    "    from configs.configs_model_type import model_configs\n",
    "    from protenix.config.config    import parse_configs\n",
    "    from protenix.data.inference.infer_dataloader import InferenceDataset\n",
    "    from runner.inference import (InferenceRunner,\n",
    "                                  update_gpu_compatible_configs,\n",
    "                                  update_inference_configs)\n",
    "\n",
    "    def build_cfg(inp,dump,n):\n",
    "        base={**cfg_base,**{'data':data_configs},**inference_configs}\n",
    "        def _u(t,p):\n",
    "            for k,v in p.items():\n",
    "                if isinstance(v,dict) and k in t and isinstance(t[k],dict): _u(t[k],v)\n",
    "                else: t[k]=v\n",
    "        _u(base,model_configs[MODEL_NAME])\n",
    "        return parse_configs(configs=base,fill_required_with_null=True,arg_str=' '.join([\n",
    "            f'--model_name {MODEL_NAME}',f'--input_json_path {inp}',f'--dump_dir {dump}',\n",
    "            f'--use_msa {USE_MSA}',f'--use_template {USE_TMPL}',\n",
    "            f'--use_rna_msa {USE_RNA_MSA}',\n",
    "            f'--sample_diffusion.N_sample {n}',f'--seeds {SEED}',\n",
    "        ]))\n",
    "\n",
    "    def extract_c1(pred,feat,slen):\n",
    "        raw=pred['coordinate']\n",
    "        if 'centre_atom_mask' in feat: mask=(feat['centre_atom_mask']==1).to(raw.device)\n",
    "        elif 'atom_to_tokatom_idx' in feat:\n",
    "            m11=(feat['atom_to_tokatom_idx']==11).to(raw.device)\n",
    "            m12=(feat['atom_to_tokatom_idx']==12).to(raw.device)\n",
    "            mask=m11 if abs(m11.sum()-slen)<abs(m12.sum()-slen) else m12\n",
    "        else: mask=torch.zeros(raw.shape[1],dtype=torch.bool,device=raw.device)\n",
    "        c=raw[:,mask,:].detach().cpu().numpy()\n",
    "        if c.shape[1]>1 and np.all(np.linalg.norm(c[0,1:]-c[0,:-1],axis=-1)<1e-4): return None\n",
    "        if c.shape[1]!=slen:\n",
    "            pad=np.zeros((c.shape[0],slen,3),np.float32)\n",
    "            ml=min(c.shape[1],slen); pad[:,:ml]=c[:,:ml]; c=pad\n",
    "        return c\n",
    "\n",
    "    work=Path('/kaggle/working'); tasks=[]; chunk_info={}; seq_lookup={}\n",
    "    for tid,(n_need,seq) in ptx_queue.items():\n",
    "        L=len(seq); chunks=_split(L,MAX_SEQ_LEN,CHUNK_OVERLAP); chunk_info[tid]=[]\n",
    "        for ci,(cs,ce) in enumerate(chunks):\n",
    "            nm=f'{tid}_chunk{ci}' if len(chunks)>1 else tid\n",
    "            tasks.append({'target_id':nm,'sequence':seq[cs:ce]})\n",
    "            chunk_info[tid].append({'name':nm,'range':(cs,ce)})\n",
    "            seq_lookup[nm]=seq[cs:ce]\n",
    "\n",
    "    inp_json=str(work/'ptx_input.json')\n",
    "    with open(inp_json,'w') as fh:\n",
    "        json.dump([{'name':r['target_id'],'covalent_bonds':[],\n",
    "                    'sequences':[{'rnaSequence':{'sequence':r['sequence'],'count':1}}]}\n",
    "                   for _,r in pd.DataFrame(tasks).iterrows()],fh)\n",
    "\n",
    "    cfg=build_cfg(inp_json,str(work/'ptx_out'),N_SAMPLE)\n",
    "    cfg=update_gpu_compatible_configs(cfg)\n",
    "    runner=InferenceRunner(cfg); dataset=InferenceDataset(cfg); raw_preds={}\n",
    "\n",
    "    for i in tqdm(range(len(dataset)),desc='Protenix+RNet2'):\n",
    "        data,aa,err=dataset[i]; sname=data.get('sample_name',f's{i}')\n",
    "        if err:\n",
    "            raw_preds[sname]=None\n",
    "            del data,aa,err; gc.collect(); torch.cuda.empty_cache(); continue\n",
    "        tid_base=sname.split('_chunk')[0] if '_chunk' in sname else sname\n",
    "        n_need=ptx_queue.get(tid_base,(N_SAMPLE,''))[0]\n",
    "        sub_len=data['N_token'].item()\n",
    "        try:\n",
    "            sub_seq=seq_lookup.get(sname,'')\n",
    "            if sub_seq and len(sub_seq)==sub_len:\n",
    "                data=inject_rnet2(data,sub_seq)\n",
    "            new_cfg=update_inference_configs(cfg,sub_len)\n",
    "            new_cfg.sample_diffusion.N_sample=n_need\n",
    "            runner.update_model_configs(new_cfg)\n",
    "            pred=runner.predict(data)\n",
    "            raw_preds[sname]=extract_c1(pred,data['input_feature_dict'],sub_len)\n",
    "        except Exception as ex:\n",
    "            print(f'  {sname}: {ex}'); raw_preds[sname]=None\n",
    "        finally:\n",
    "            try: del pred,data,aa\n",
    "            except: pass\n",
    "            gc.collect(); torch.cuda.empty_cache()\n",
    "\n",
    "    for tid,(n_need,seq) in ptx_queue.items():\n",
    "        L=len(seq); cinfos=chunk_info.get(tid,[])\n",
    "        if not cinfos: continue\n",
    "        if len(cinfos)==1:\n",
    "            ptx_preds[tid]=raw_preds.get(tid)\n",
    "        else:\n",
    "            per=[[] for _ in range(n_need)]; ok=True\n",
    "            for ci in cinfos:\n",
    "                c=raw_preds.get(ci['name'])\n",
    "                if c is None: ok=False; break\n",
    "                for si in range(n_need): per[si].append((c[min(si,len(c)-1)],ci['range']))\n",
    "            if not ok: ptx_preds[tid]=None; continue\n",
    "            stitched=[stitch_chunks([c for c,_ in it],[r for _,r in it],L) for it in per]\n",
    "            ptx_preds[tid]=np.stack(stitched,0)\n",
    "            print(f'  {tid}: stitched {len(stitched)} predictions')\n",
    "\n",
    "elif ptx_queue and not PTX_DIR:\n",
    "    print(f'Phase 2 skipped — attach qiweiyin/protenix-v1-adjusted to enable Protenix')\n",
    "elif ptx_queue and not USE_PROTENIX:\n",
    "    print(f'Phase 2 skipped (USE_PROTENIX=False)')\n",
    "else:\n",
    "    print('Phase 2: all targets covered by TBM.')\n"
   ]
