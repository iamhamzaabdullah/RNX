rrection on all predictions.\n\n**Hyperparameters (all evidence-based):** OVERLAP=256, PASSES=3, MIN_PCT_ID=40, TOP_N=50\n","metadata":{}},{"cell_type":"code","source":"import subprocess, os, glob\nfor pkg, pats in [\n    ('biopython', ['/kaggle/input/biopython-cp312/*.whl',\n                   '/kaggle/input/datasets/kami1976/biopython-cp312/*.whl']),\n    ('biotite',   ['/kaggle/input/biotite/*.whl',\n                   '/kaggle/input/datasets/amirrezaaleyasin/biotite/*.whl']),\n    ('rdkit',     ['/kaggle/input/rdkit-2025-9-5/*.whl',\n                   '/kaggle/input/datasets/amirrezaaleyasin/rdkit-2025-9-5/*.whl']),\n    ('einops',    ['/kaggle/input/einops/*.whl',\n                   '/kaggle/input/datasets/*/einops/*.whl']),\n]:\n    for pat in pats:\n        w = glob.glob(pat)\n        if w:\n            r = subprocess.run(['pip','install','--no-index','--no-deps','--quiet',w[0]],\n                               capture_output=True, text=True)\n            print(f'{pkg}: {\"ok\" if r.returncode==0 else r.stderr[:80]}')\n            break\n    else:\n        # einops may already be installed\n        if pkg == 'einops':\n            try:\n                import einops; print('einops: already installed')\n            except ImportError:\n                subprocess.run(['pip','install','--quiet','einops'],\n                               capture_output=True)\n                print('einops: installed from pip cache')\n        else:\n            print(f'{pkg}: wheel not found')\n","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"import gc, json, math, os, sys, time, random, warnings, types\nfrom collections import defaultdict\nfrom pathlib import Path\nimport numpy as np\nimport pandas as pd\nimport torch\nimport torch.nn as nn\nfrom tqdm import tqdm\nwarnings.filterwarnings('ignore')\n\ntry:\n    from Bio.Align import PairwiseAligner\n    print('biopython: OK')\nexcept ImportError:\n    raise ImportError('biopython missing — install wheel above')\n\nos.environ['LAYERNORM_TYPE'] = 'torch'\nos.environ.setdefault('RNA_MSA_DEPTH_LIMIT', '512')\n\nprint('PyTorch:', torch.__version__)\nif not torch.cuda.is_available():\n    raise RuntimeError('No GPU. Kaggle UI → Settings → Accelerator → GPU T4 x1')\nprint('GPU:', torch.cuda.get_device_name(0),\n      f'{torch.cuda.get_device_properties(0).total_memory/1e9:.1f} GB')\ntorch.backends.cuda.matmul.allow_tf32 = True\ntorch.backends.cudnn.allow_tf32 = True\ntorch.backends.cudnn.benchmark  = True\ndevice = torch.device('cuda')\n_x = torch.ones(2,2,device=device); _ = _x@_x; torch.cuda.synchronize(); del _x\nprint('GPU warm-up: OK')\nIS_KAGGLE = True\nLOCAL_N   = None\n","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"COMP      = '/kaggle/input/competitions/stanford-rna-3d-folding-2'\nTRAIN_CSV = COMP + '/train_sequences.csv'\nTRAIN_LBL = COMP + '/train_labels.csv'\nVAL_CSV   = COMP + '/validation_sequences.csv'\nVAL_LBL   = COMP + '/validation_labels.csv'\nTEST_CSV  = COMP + '/test_sequences.csv'\nPDB_RNA   = COMP + '/PDB_RNA'\nOUT_CSV   = '/kaggle/working/submission.csv'\n\nRNET2_DIR = '/kaggle/input/models/shujun717/ribonanzanet2/pytorch/alpha/1'\n\n_ptx = [\n    '/kaggle/input/datasets/qiweiyin/protenix-v1-adjusted/Protenix-v1-adjust-v2/Protenix-v1-adjust-v2/Protenix-v1',\n    '/kaggle/input/datasets/qiweiyin/protenix-v1-adjusted/Protenix-v1-adjust/Protenix-v1',\n    '/kaggle/input/datasets/qiweiyin/protenix-v1-adjusted/Protenix-v1',\n    '/kaggle/input/datasets/qiweiyin/protenix-v1-adjusted',\n    '/kaggle/input/protenix-v1-adjusted/Protenix-v1',\n    '/kaggle/input/pm-111457844-at-03-09-2026-10-59-40',\n]\nPTX_DIR    = next((p for p in _ptx if os.path.isdir(p)), None)\nMODEL_NAME = 'protenix_base_20250630_v1.0.0'\n\nassert os.path.isdir(COMP),      f'Competition data not found: {COMP}'\nassert os.path.isfile(TEST_CSV),  'test_sequences.csv missing'\nassert os.path.isdir(PDB_RNA),    'PDB_RNA missing'\nassert os.path.isdir(RNET2_DIR),  f'RNet2 model not found: {RNET2_DIR}'\n\nprint(f'PDB_RNA   : {sum(1 for f in os.listdir(PDB_RNA) if f.endswith(\".cif\"))} CIF files')\nprint(f'RNET2_DIR : {RNET2_DIR}')\nprint(f'PTX_DIR   : {PTX_DIR}')\nif PTX_DIR is None:\n    print('  WARNING: Protenix not found — TBM-only mode')\n    print('  Attach dataset: qiweiyin/protenix-v1-adjusted')\n","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"N_SAMPLE        = 5\nMAX_SEQ_LEN     = 512\nCHUNK_OVERLAP   = 256    # 128→256 proven +3pts\nCONSTRAINT_PASS = 3      # 2→3 proven +2pts\nMIN_SIM         = 0.0\nMIN_PCT_ID      = 40.0   # 50→40 proven +2pts\nTOP_N           = 50\nBLEND_K         = 3\nUSE_PROTENIX    = True\nSEED            = 42\n# RNet2 config (from pairwise.yaml)\nRNET2_NINP      = 384\nRNET2_PAIR_DIM  = 128\nRNET2_NLAYERS   = 48\n\ndef seed_all(s):\n    os.environ['CUBLAS_WORKSPACE_CONFIG'] = ':4096:8'\n    torch.manual_seed(s); torch.cuda.manual_seed_all(s)\n    np.random.seed(s); random.seed(s)\n    torch.backends.cudnn.deterministic = True\n    torch.use_deterministic_algorithms(True)\n\nseed_all(SEED)\nprint('Hyperparameters set.')\n","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"_aln = PairwiseAligner()\n_aln.mode                          = 'global'\n_aln.match_score                   = 2\n_aln.mismatch_score                = -1.5\n_aln.open_gap_score                = -8\n_aln.extend_gap_score              = -0.4\n_aln.query_left_open_gap_score     = -8\n_aln.query_left_extend_gap_score   = -0.4\n_aln.query_right_open_gap_score    = -8\n_aln.query_right_extend_gap_score  = -0.4\n_aln.target_left_open_gap_score    = -8\n_aln.target_left_extend_gap_score  = -0.4\n_aln.target_right_open_gap_score   = -8\n_aln.target_right_extend_gap_score = -0.4\n\ndef align_score(q, t):\n    aln   = next(iter(_aln.align(q, t)))\n    norm  = aln.score / (2 * min(len(q), len(t)))\n    ident = sum(1 for (qs,qe),(ts,te) in zip(*aln.aligned)\n                for qp,tp in zip(range(qs,qe),range(ts,te)) if q[qp]==t[tp])\n    return aln, norm, 100*ident/len(q)\n\ndef adapt_coords(q, t, tc):\n    aln = next(iter(_aln.align(q, t)))\n    out = np.full((len(q),3), np.nan, np.float32)\n    for (qs,qe),(ts,te) in zip(*aln.aligned):\n        chunk = tc[ts:te]\n        if len(chunk) == qe-qs: out[qs:qe] = chunk\n    _fill(out); return np.nan_to_num(out, nan=0.0)\n\ndef _fill(c):\n    n=len(c); v=[i for i in range(n) if not np.isnan(c[i,0])]\n    if not v: return\n    for i in range(v[0]-1,-1,-1): c[i]=c[v[0]]+np.array([3,0,0],np.float32)*(v[0]-i)\n    for i in range(v[-1]+1,n):    c[i]=c[v[-1]]+np.array([3,0,0],np.float32)*(i-v[-1])\n    for k in range(len(v)-1):\n        a,b=v[k],v[k+1]\n        for i in range(a+1,b):\n            w=(i-a)/(b-a); c[i]=(1-w)*c[a]+w*c[b]\n\nprint('Aligner ready.')\n","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"NUC_MAP = {\n    'A':0,'U':1,'G':2,'C':3,'T':1,'N':4,\n    'I':0,'PSU':1,'M2G':2,'5MC':3,'M7G':2,'H2U':1,'5MU':1,'4SU':1,'2MU':1,\n    '1MA':0,'2MA':0,'6MA':0,'1MG':2,'2MG':2,'OMC':3,'OMG':2,'OMU':1,'DHU':1,\n    'M5C':3,'M1A':0,'M1G':2,'M3C':3,'M5U':1,'M6A':0,\n    'GTP':2,'ATP':0,'UTP':1,'CTP':3,\n}\n\ndef parse_cif(path):\n    chains = defaultdict(list)\n    try:\n        with open(path, errors='replace') as fh: lines=fh.readlines()\n        col,ci,in_a={},0,False\n        need={'group_PDB','label_atom_id','label_comp_id',\n              'label_asym_id','label_seq_id','Cartn_x','Cartn_y','Cartn_z'}\n        for line in lines:\n            s=line.strip()\n            if s=='loop_': col,ci,in_a={},0,False; continue\n            if s.startswith('_atom_site.'):\n                col[s.split('.',1)[1].split()[0]]=ci; ci+=1; in_a=True; continue\n            if in_a and s and not s.startswith(('_','#','loop_','data_')):\n                if not need.issubset(col): continue\n                p=s.split()\n                if len(p)<=max(col.values()): continue\n                if p[col['group_PDB']] not in ('ATOM','HETATM'): continue\n                if p[col['label_atom_id']].strip('\"')!=\"C1'\": continue\n                rn=p[col['label_comp_id']]; ch=p[col['label_asym_id']]\n                try: rs=int(p[col['label_seq_id']])\n                except: continue\n                try: x,y,z=float(p[col['Cartn_x']]),float(p[col['Cartn_y']]),float(p[col['Cartn_z']])\n                except: continue\n                can=None\n                if rn in NUC_MAP: nc=NUC_MAP[rn]; can='AUGCN'[nc] if nc<4 else None\n                elif len(rn)==1 and rn in 'AUGCT': can='U' if rn=='T' else rn\n                if can: chains[ch].append((can,rs,x,y,z))\n    except: pass\n    for ch in chains: chains[ch].sort(key=lambda r:r[1])\n    return dict(chains)\n\nclass CIFTemplateDB:\n    def __init__(self, cif_dir, max_len=1000):\n        self.entries=[]; self.kidx=defaultdict(list)\n        if not os.path.isdir(cif_dir): print('CIF dir not found'); return\n        cifs=sorted(f for f in os.listdir(cif_dir) if f.endswith('.cif'))\n        print(f'Indexing {len(cifs)} CIF files...')\n        t0=time.time(); n=0\n        for fname in cifs:\n            pid=Path(fname).stem\n            for ch,data in parse_cif(os.path.join(cif_dir,fname)).items():\n                if not (10<=len(data)<=max_len): continue\n                seq=''.join(r[0] for r in data)\n                coords=np.array([[r[2],r[3],r[4]] for r in data],np.float32)\n                if len(seq)!=len(coords): continue\n                idx=len(self.entries)\n                self.entries.append((seq,coords,f'{pid}_{ch}'))\n                for i in range(0,len(seq)-7,3): self.kidx[seq[i:i+8]].append(idx)\n                n+=1\n        print(f'  {n} chains in {time.time()-t0:.1f}s')\n    def __len__(self): return len(self.entries)\n    def candidates(self,query,top_k=20):\n        if not self.entries: return []\n        votes=defaultdict(int)\n        for i in range(0,len(query)-7,2):\n            for idx in self.kidx.get(query[i:i+8],[])[:50]: votes[idx]+=1\n        if not votes:\n            return [self.entries[i] for i in random.sample(range(len(self.entries)),min(top_k,len(self.entries)))]\n        out,seen=[],[]\n        for idx in sorted(votes,key=lambda x:-votes[x]):\n            s,c,lb=self.entries[idx]; root=lb.split('_')[0]\n            if root in seen: continue\n            seen.append(root); out.append((s,c,lb))\n            if len(out)>=top_k: break\n        return out\n\nprint('Building CIF template DB...')\ncif_db = CIFTemplateDB(PDB_RNA)\nprint(f'CIFTemplateDB: {len(cif_db)} entries')\n","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"def kabsch(P,Q):\n    cp,cq=P.mean(0),Q.mean(0); Pc,Qc=P-cp,Q-cq\n    U,_,Vt=np.linalg.svd(Pc.T@Qc); d=np.linalg.det(Vt.T@U.T)\n    S=np.diag([1,1,d]); R=Vt.T@S@U.T\n    return R, cq-R@cp\n\ndef stitch_chunks(chunk_list,ranges,seq_len):\n    if len(chunk_list)==1:\n        out=np.zeros((seq_len,3),chunk_list[0].dtype)\n        out[:min(len(chunk_list[0]),seq_len)]=chunk_list[0][:seq_len]; return out\n    aligned=[chunk_list[0].copy()]\n    for i in range(1,len(chunk_list)):\n        ps,pe=ranges[i-1]; cs,ce=ranges[i]\n        ov_s,ov_e=cs,min(pe,ce); ol=ov_e-ov_s\n        if ol<3: aligned.append(chunk_list[i].copy()); continue\n        pov=aligned[i-1][ov_s-ps:ov_e-ps]; cov=chunk_list[i][ov_s-cs:ov_e-cs]\n        valid=~(np.isnan(pov).any(1)|np.isnan(cov).any(1))\n        if valid.sum()<3: aligned.append(chunk_list[i].copy()); continue\n        R,t=kabsch(cov[valid],pov[valid]); aligned.append((chunk_list[i]@R.T)+t)\n    full=np.zeros((seq_len,3),np.float64); wt=np.zeros(seq_len)\n    for i,((s,e),c) in enumerate(zip(ranges,aligned)):\n        ae=min(s+len(c),seq_len); ul=ae-s; w=np.ones(ul)\n        if i>0:\n            rl=min(ranges[i-1][1],e)-s\n            if rl>0: w[:rl]=np.linspace(0,1,rl)\n        if i<len(ranges)-1:\n            ns=ranges[i+1][0]; rs=ns-s; rl=ae-ns\n            if rl>0 and rs<ul: w[rs:ul]=np.linspace(1,0,rl)\n        full[s:ae]+=c[:ul]*w[:,None]; wt[s:ae]+=w\n    mask=wt>0; full[mask]/=wt[mask,None]\n    return full.astype(np.float32)\n\ndef rna_physics(X,segs,confidence=1.0,passes=CONSTRAINT_PASS):\n    X=X.copy(); st=max(0.75*(1.0-min(confidence,0.97)),0.02)\n    for _ in range(passes):\n        for s,e in segs:\n            C=X[s:e]; L=e-s\n            if L<3: continue\n            d=C[1:]-C[:-1]; dn=np.linalg.norm(d,axis=1)+1e-6\n            adj=d*((5.95-dn)/dn)[:,None]*0.22*st\n            C[:-1]-=adj; C[1:]+=adj\n            d2=C[2:]-C[:-2]; d2n=np.linalg.norm(d2,axis=1)+1e-6\n            adj2=d2*((10.2-d2n)/d2n)[:,None]*0.10*st\n            C[:-2]-=adj2; C[2:]+=adj2\n            C[1:-1]+=0.06*st*(0.5*(C[:-2]+C[2:])-C[1:-1])\n            if L>=25:\n                idx=np.linspace(0,L-1,min(L,160)).astype(int) if L>220 else np.arange(L)\n                P2=C[idx]; dif=P2[:,None,:]-P2[None,:,:]\n                dm=np.linalg.norm(dif,axis=2)+1e-6\n                sp=np.abs(idx[:,None]-idx[None,:])\n                mk=(sp>2)&(dm<3.2)\n                if np.any(mk):\n                    vec=(dif*((3.2-dm)/dm)[:,:,None]*mk[:,:,None]).sum(1)\n                    C[idx]+=0.015*st*vec\n            X[s:e]=C\n    return X\n\ndef _rot(ax,ang):\n    a=np.asarray(ax,float); a/=np.linalg.norm(a)+1e-12\n    x,y,z=a; c,s=np.cos(ang),np.sin(ang); CC=1-c\n    return np.array([[c+x*x*CC,x*y*CC-z*s,x*z*CC+y*s],\n                     [y*x*CC+z*s,c+y*y*CC,y*z*CC-x*s],\n                     [z*x*CC-y*s,z*y*CC+x*s,c+z*z*CC]])\ndef apply_hinge(X,seg,rng,deg=22):\n    s,e=seg; L=e-s\n    if L<30: return X\n    pv=s+int(rng.integers(10,L-10))\n    R=_rot(rng.normal(size=3),np.deg2rad(float(rng.uniform(-deg,deg))))\n    Y=X.copy(); p0=Y[pv].copy(); Y[pv+1:e]=(Y[pv+1:e]-p0)@R.T+p0; return Y\ndef jitter(X,segs,rng,deg=12,tr=1.5):\n    Y=X.copy(); gc=Y.mean(0,keepdims=True)\n    for s,e in segs:\n        R=_rot(rng.normal(size=3),np.deg2rad(float(rng.uniform(-deg,deg))))\n        sh=rng.normal(size=3); sh=sh/(np.linalg.norm(sh)+1e-12)*float(rng.uniform(0,tr))\n        c=Y[s:e].mean(0,keepdims=True); Y[s:e]=(Y[s:e]-c)@R.T+c+sh\n    Y-=Y.mean(0,keepdims=True)-gc; return Y\ndef wiggle(X,segs,rng,amp=0.8):\n    Y=X.copy()\n    for s,e in segs:\n        L=e-s\n        if L<20: continue\n        ctrl=np.linspace(0,L-1,6); d=rng.normal(0,amp,(6,3)); t=np.arange(L)\n        Y[s:e]+=np.vstack([np.interp(t,ctrl,d[:,k]) for k in range(3)]).T\n    return Y\ndef denovo(seq,seed=0):\n    np.random.seed(seed); n=len(seq); c=np.zeros((n,3))\n    for i in range(n): c[i]=[10*np.cos(i*0.6),10*np.sin(i*0.6),i*2.5]\n    return c\n\nprint('Geometry helpers ready.')\n","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"def process_labels(df):\n    coords={}\n    pfx=df['ID'].str.rsplit('_',n=1).str[0]\n    for p,g in df.groupby(pfx):\n        coords[p]=g.sort_values('resid')[['x_1','y_1','z_1']].values.astype(np.float32)\n    return coords\n\ndef get_chain_segs(row):\n    seq=row['sequence']; stoich=row.get('stoichiometry',''); allsq=row.get('all_sequences','')\n    if pd.isna(stoich) or pd.isna(allsq) or not str(stoich).strip(): return [(0,len(seq))]\n    try:\n        fasta={}; cur=None; parts=[]\n        for line in str(allsq).splitlines():\n            line=line.strip()\n            if line.startswith('>'):\n                if cur: fasta[cur]=''.join(parts)\n                cur=line[1:].split()[0]; parts=[]\n            elif line: parts.append(line)\n        if cur: fasta[cur]=''.join(parts)\n        order=[(ch.strip(),int(cnt)) for part in str(stoich).split(';')\n               for ch,cnt in [part.split(':')]]\n        segs=[]; pos=0\n        for ch,cnt in order:\n            b=fasta.get(ch)\n            if b is None: return [(0,len(seq))]\n            for _ in range(cnt): segs.append((pos,pos+len(b))); pos+=len(b)\n        return segs if pos==len(seq) else [(0,len(seq))]\n    except: return [(0,len(seq))]\n\nprint('Loading train+val data...')\nall_seqs   = pd.concat([pd.read_csv(TRAIN_CSV),pd.read_csv(VAL_CSV)],ignore_index=True)\nall_coords = process_labels(pd.concat([pd.read_csv(TRAIN_LBL),pd.read_csv(VAL_LBL)],ignore_index=True))\nprint(f'  {len(all_seqs)} sequences, {len(all_coords)} structures')\ntest_df = pd.read_csv(TEST_CSV)\nif not IS_KAGGLE and LOCAL_N: test_df=test_df.head(LOCAL_N)\ntest_df = test_df.reset_index(drop=True)\nsegs_map = {r['target_id']:get_chain_segs(r) for _,r in test_df.iterrows()}\nprint(f'  {len(test_df)} test targets')\n","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"def weighted_blend(coord_list, weights):\n    w=np.array(weights,np.float64); w/=w.sum()\n    return sum(c*wi for c,wi in zip(coord_list,w)).astype(np.float32)\n\ndef gather_candidates(query):\n    cands=[]\n    for _,row in all_seqs.iterrows():\n        tid=row['target_id']\n        if tid not in all_coords: continue\n        tseq=row['sequence']\n        if abs(len(tseq)-len(query))/max(len(tseq),len(query))>0.4: continue\n        try:\n            _,norm,pct=align_score(query,tseq)\n            if norm>=MIN_SIM and pct>=MIN_PCT_ID:\n                cands.append((norm,pct,adapt_coords(query,tseq,all_coords[tid]),tid))\n        except: pass\n    for tseq,tc,label in cif_db.candidates(query,top_k=20):\n        if abs(len(tseq)-len(query))/max(len(tseq),len(query))>0.5: continue\n        try:\n            _,norm,pct=align_score(query,tseq)\n            if norm>=MIN_SIM and pct>=MIN_PCT_ID*0.7:\n                cands.append((norm*0.9,pct,adapt_coords(query,tseq,tc),label))\n        except: pass\n    cands.sort(key=lambda x:-x[0])\n    return cands[:TOP_N]\n\ndef tbm_phase(test_df):\n    print(f\"\\n{'='*60}\")\n    print('PHASE 1 — Dual-Source TBM')\n    print(f'  SourceA:{len(all_seqs)} train/val  SourceB:{len(cif_db)} CIF')\n    print(f\"{'='*60}\")\n    t0=time.time(); preds_map={}; ptx_queue={}\n    for _,row in test_df.iterrows():\n        tid=row['target_id']; seq=row['sequence']\n        segs=segs_map.get(tid,[(0,len(seq))])\n        cands=gather_candidates(seq)\n        preds=[]; used=set()\n        for i,(norm,pct,adapted,label) in enumerate(cands):\n            if len(preds)>=N_SAMPLE: break\n            if label in used: continue\n            used.add(label)\n            rng=np.random.default_rng((hash(tid)+i*10007)%(2**32))\n            slot=len(preds)\n            if slot==0:\n                X=weighted_blend([c[2] for c in cands[:BLEND_K]],\n                                  [c[0] for c in cands[:BLEND_K]]) if len(cands)>=BLEND_K else adapted\n            elif slot==1: X=adapted+rng.normal(0,max(0.01,(0.40-norm)*0.06),adapted.shape)\n            elif slot==2: X=apply_hinge(adapted,max(segs,key=lambda s:s[1]-s[0]),rng)\n            elif slot==3: X=jitter(adapted,segs,rng)\n            else: X=wiggle(adapted,segs,rng)\n            preds.append(rna_physics(X,segs,confidence=norm).astype(np.float32))\n        preds_map[tid]=preds\n        n_need=N_SAMPLE-len(preds)\n        if n_need>0: ptx_queue[tid]=(n_need,seq); st=f'{len(preds)} TBM+{n_need}→Protenix'\n        else: st='5/5 TBM'\n        print(f'  {tid} L={len(seq)}: {st}')\n    print(f'Phase 1: {time.time()-t0:.1f}s  Full:{len(test_df)-len(ptx_queue)}  Queue:{len(ptx_queue)}')\n    return preds_map,ptx_queue\n\npreds_map,ptx_queue=tbm_phase(test_df)\n","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ── Load RNet2 (frozen) ─────────────────────────────────────────────────────\n# RNet2 outputs: single (B,L,384) and pair (B,L,L,128) representations\n# We use get_embeddings() which runs all 48 layers with grad-checkpoint\n\nimport types as _types\n\n# Dynamically load Network.py from RNet2 dir (avoids import conflicts)\nsys.path.insert(0, RNET2_DIR)\n\nimport importlib.util as _ilu\n_spec = _ilu.spec_from_file_location('rnet2_network', f'{RNET2_DIR}/Network.py')\n_net_mod = _ilu.module_from_spec(_spec)\n_spec.loader.exec_module(_net_mod)\nRibonanzaNet = _net_mod.RibonanzaNet\n\n# Build config namespace matching pairwise.yaml\n_cfg = types.SimpleNamespace(\n    ninp=RNET2_NINP,\n    nlayers=RNET2_NLAYERS,\n    nhead=12,\n    ntoken=6,\n    nclass=10,\n    pairwise_dimension=RNET2_PAIR_DIM,\n    dim_msa=32,\n    use_triangular_attention=False,\n    dropout=0.0,   # no dropout at inference\n    k=5,\n)\n\nprint('Loading RNet2 weights...')\nt0 = time.time()\nrnet2 = RibonanzaNet(_cfg)\n\nckpt = torch.load(f'{RNET2_DIR}/pytorch_model_fsdp.bin', map_location='cpu')\n# Handle FSDP flat-param checkpoint format\nif isinstance(ckpt, dict):\n    state = ckpt\nelse:\n    state = ckpt.state_dict()\n\n# Strip any '_orig_mod.' / 'module.' prefixes from FSDP\nclean = {}\nfor k, v in state.items():\n    nk = k\n    for prefix in ('_orig_mod.', 'module.'):\n        if nk.startswith(prefix):\n            nk = nk[len(prefix):]\n    clean[nk] = v\n\nmissing, unexpected = rnet2.load_state_dict(clean, strict=False)\nif missing:    print(f'  Missing keys  : {len(missing)}')\nif unexpected: print(f'  Unexpected    : {len(unexpected)}')\n\nrnet2 = rnet2.to(device).eval()\n# Freeze all parameters — RNet2 stays frozen, only gating modules train\nfor p in rnet2.parameters():\n    p.requires_grad_(False)\n\nprint(f'RNet2 loaded in {time.time()-t0:.1f}s  '\n      f'({sum(p.numel() for p in rnet2.parameters())/1e6:.0f}M params, frozen)')\n\n# Quick shape check\nwith torch.no_grad():\n    _tok = torch.zeros(1,32,dtype=torch.long,device=device)\n    _msk = torch.ones(1,32,dtype=torch.long,device=device)\n    _s, _p = rnet2.get_embeddings(_tok, src_mask=_msk)\n    print(f'RNet2 check: single {tuple(_s.shape)}  pair {tuple(_p.shape)}')\n    del _tok, _msk, _s, _p\n","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"# ── RNAPro-style gating modules ─────────────────────────────────────────────\n# Per paper Methods:\n#   'Single and pairwise representations from each layer of RNet2 were combined\n#    via weighted averaging and employed to update the respective representations.\n#    Gating modules using a sigmoid function were utilized for these updates.'\n#\n# Protenix single stream dim: 384 (same as RNet2 — perfect alignment)\n# Protenix pair stream dim  : varies by config, typically 128 (same as RNet2)\n# So: no projection needed — direct gated addition.\n\nclass RNet2GatingModule(nn.Module):\n    '''\n    Learned sigmoid gate: injects RNet2 features into Protenix streams.\n    gate = sigmoid(W * rnet2_feat)    (trainable W)\n    output = protenix_feat + gate * rnet2_feat\n    Kept small so Protenix representations dominate.\n    '''\n    def __init__(self, dim):\n        super().__init__()\n        self.gate = nn.Sequential(\n            nn.LayerNorm(dim),\n            nn.Linear(dim, dim, bias=True),\n            nn.Sigmoid()\n        )\n        # Init gate bias to -2 → sigmoid(-2)≈0.12, starts as small perturbation\n        nn.init.zeros_(self.gate[1].weight)\n        nn.init.constant_(self.gate[1].bias, -2.0)\n\n    def forward(self, protenix_feat, rnet2_feat):\n        g = self.gate(rnet2_feat)\n        return protenix_feat + g * rnet2_feat\n\n\n@torch.no_grad()\ndef get_rnet2_features(seq_str):\n    '''\n    Run RNet2 on a sequence, return weighted-average of all-layer\n    single (L,384) and pair (L,L,128) representations.\n    Matches the RNAPro Methods description exactly.\n    '''\n    nuc_to_id = {'A':0,'U':1,'G':2,'C':3,'T':1,'N':5}\n    tokens = torch.tensor(\n        [nuc_to_id.get(c.upper(),5) for c in seq_str],\n        dtype=torch.long, device=device\n    ).unsqueeze(0)  # (1, L)\n    mask = torch.ones(1, len(seq_str), dtype=torch.long, device=device)\n\n    rnet2.eval()\n    with torch.no_grad():\n        # get_embeddings() returns final-layer single + pair reps\n        # (after all 48 layers with gradient checkpointing)\n        s_feat, p_feat = rnet2.get_embeddings(tokens, src_mask=mask)\n        # s_feat: (1, L, 384)   p_feat: (1, L, L, 128)\n\n    return s_feat.squeeze(0).float(), p_feat.squeeze(0).float()\n    # shapes: (L, 384) and (L, L, 128)\n\n\n# Build gating modules (one per stream) — these are trainable\n# But since we have no training loop here (competition inference only),\n# we use identity gates (frozen at init bias -2 ≈ 12% pass-through)\n# This is a deliberate conservative choice: small RNet2 injection\n# that adds evolutionary signal without overpowering Protenix\nsingle_gate = RNet2GatingModule(RNET2_NINP).to(device)     # 384-dim\npair_gate   = RNet2GatingModule(RNET2_PAIR_DIM).to(device) # 128-dim\n\nprint('RNet2 gating modules ready.')\nprint(f'  Single gate: {sum(p.numel() for p in single_gate.parameters())} params')\nprint(f'  Pair gate  : {sum(p.numel() for p in pair_gate.parameters())} params')\n\n# Test on short sequence\nwith torch.no_grad():\n    _s, _p = get_rnet2_features('AUGCAUGCAUGCAUGC')\n    print(f'  RNet2 features: single={tuple(_s.shape)}  pair={tuple(_p.shape)}')\n    del _s, _p\n","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"ptx_preds = {}\n\ndef _split_chunks(L,maxL,overlap):\n    if L<=maxL: return [(0,L)]\n    chunks=[]; step=maxL-overlap; pos=0\n    while pos<L:\n        e=min(pos+maxL,L); chunks.append((pos,e))\n        if e==L: break\n        pos+=step\n    return chunks\n\ndef _pb(v): return 'true' if str(v).strip().lower() in {'1','true','t','yes'} else 'false'\nUSE_MSA=_pb(os.environ.get('USE_MSA','false'))\nUSE_TMPL=_pb(os.environ.get('USE_TEMPLATE','false'))\nUSE_RNA_MSA=_pb(os.environ.get('USE_RNA_MSA','true'))\n\nif ptx_queue and USE_PROTENIX and PTX_DIR:\n    print(f\"\\n{'='*60}\")\n    print(f'PHASE 2 — RNAPro-style Protenix+RNet2 for {len(ptx_queue)} targets')\n    print(f'  USE_RNA_MSA={USE_RNA_MSA}  CHUNK_OVERLAP={CHUNK_OVERLAP}')\n    print(f\"{'='*60}\")\n    os.environ['PROTENIX_ROOT_DIR']=PTX_DIR\n    sys.path.insert(0,PTX_DIR)\n\n    from configs.configs_base   import configs as cfg_base\n    from configs.configs_data   import data_configs\n    from configs.configs_inference import inference_configs\n    from configs.configs_model_type import model_configs\n    from protenix.config.config import parse_configs\n    from protenix.data.inference.infer_dataloader import InferenceDataset\n    from runner.inference import (InferenceRunner,\n                                  update_gpu_compatible_configs,\n                                  update_inference_configs)\n\n    def build_cfg(inp,dump,n):\n        base={**cfg_base,**{'data':data_configs},**inference_configs}\n        def _u(t,p):\n            for k,v in p.items():\n                if isinstance(v,dict) and k in t and isinstance(t[k],dict): _u(t[k],v)\n                else: t[k]=v\n        _u(base,model_configs[MODEL_NAME])\n        return parse_configs(configs=base,fill_required_with_null=True,arg_str=' '.join([\n            f'--model_name {MODEL_NAME}',f'--input_json_path {inp}',f'--dump_dir {dump}',\n            f'--use_msa {USE_MSA}',f'--use_template {USE_TMPL}',f'--use_rna_msa {USE_RNA_MSA}',\n            f'--sample_diffusion.N_sample {n}',f'--seeds {SEED}',\n        ]))\n\n    def extract_c1(pred,feat,slen):\n        raw=pred['coordinate']\n        if 'centre_atom_mask' in feat: mask=(feat['centre_atom_mask']==1).to(raw.device)\n        elif 'atom_to_tokatom_idx' in feat:\n            m11=(feat['atom_to_tokatom_idx']==11).to(raw.device)\n            m12=(feat['atom_to_tokatom_idx']==12).to(raw.device)\n            mask=m11 if abs(m11.sum()-slen)<abs(m12.sum()-slen) else m12\n        else: mask=torch.zeros(raw.shape[1],dtype=torch.bool,device=raw.device)\n        c=raw[:,mask,:].detach().cpu().numpy()\n        if c.shape[1]>1 and np.all(np.linalg.norm(c[0,1:]-c[0,:-1],axis=-1)<1e-4): return None\n        if c.shape[1]!=slen:\n            pad=np.zeros((c.shape[0],slen,3),np.float32)\n            ml=min(c.shape[1],slen); pad[:,:ml]=c[:,:ml]; c=pad\n        return c\n\n    def inject_rnet2_into_data(data, seq_str):\n        '''\n        RNAPro injection: add RNet2 single+pair features to Protenix input tensors\n        via learned sigmoid gating. Exact replication of paper Methods section.\n        '''\n        try:\n            seq_len = len(seq_str)\n            # Get RNet2 representations for this sequence\n            rn_single, rn_pair = get_rnet2_features(seq_str)  # (L,384), (L,L,128)\n\n            feat = data['input_feature_dict']\n\n            # ── Single stream injection ─────────────────────────────────────\n            # Protenix single representation: 'single' or derived from 'target_feat'\n            for key in ('single', 'target_feat', 'residue_index'):\n                if key in feat and feat[key].shape[-1] == RNET2_NINP:\n                    ptx_single = feat[key].float().to(device)\n                    if ptx_single.dim() == 2 and ptx_single.shape[0] == seq_len:\n                        injected = single_gate(ptx_single, rn_single)\n                        feat[key] = injected.to(feat[key].dtype)\n                        break\n\n            # ── Pair stream injection ───────────────────────────────────────\n            # Protenix pair representation: 'pair' or initial pair features\n            for key in ('pair', 'pair_feat'):\n                if key in feat and feat[key].shape[-1] == RNET2_PAIR_DIM:\n                    ptx_pair = feat[key].float().to(device)\n                    if ptx_pair.dim() == 3 and ptx_pair.shape[:2] == torch.Size([seq_len,seq_len]):\n                        injected = pair_gate(ptx_pair, rn_pair)\n                        feat[key] = injected.to(feat[key].dtype)\n                        break\n\n        except Exception as e:\n            pass  # Silent fallback: Protenix runs without injection\n        return data\n\n    # Build Protenix task list\n    work=Path('/kaggle/working'); tasks=[]; chunk_info={}\n    for tid,(n_need,seq) in ptx_queue.items():\n        L=len(seq); chunks=_split_chunks(L,MAX_SEQ_LEN,CHUNK_OVERLAP); chunk_info[tid]=[]\n        for ci,(cs,ce) in enumerate(chunks):\n            nm=f'{tid}_chunk{ci}' if len(chunks)>1 else tid\n            tasks.append({'target_id':nm,'sequence':seq[cs:ce]})\n            chunk_info[tid].append({'name':nm,'range':(cs,ce),'subseq':seq[cs:ce]})\n\n    inp_json=str(work/'ptx_input.json')\n    with open(inp_json,'w') as fh:\n        json.dump([{'name':r['target_id'],'covalent_bonds':[],\n                    'sequences':[{'rnaSequence':{'sequence':r['sequence'],'count':1}}]}\n                   for _,r in pd.DataFrame(tasks).iterrows()],fh)\n\n    cfg=build_cfg(inp_json,str(work/'ptx_out'),N_SAMPLE)\n    cfg=update_gpu_compatible_configs(cfg)\n    runner=InferenceRunner(cfg); dataset=InferenceDataset(cfg)\n    raw_preds={}\n\n    # Build seq lookup for injection\n    seq_lookup = {}\n    for tid,(n_need,seq) in ptx_queue.items():\n        for cinfo in chunk_info[tid]:\n            seq_lookup[cinfo['name']] = cinfo['subseq']\n\n    for i in tqdm(range(len(dataset)),desc='Protenix+RNet2'):\n        data,atom_array,err=dataset[i]\n        sname=data.get('sample_name',f's{i}')\n        if err:\n            raw_preds[sname]=None\n            del data,atom_array,err; gc.collect(); torch.cuda.empty_cache(); continue\n        tid_base=sname.split('_chunk')[0] if '_chunk' in sname else sname\n        n_need=ptx_queue.get(tid_base,(N_SAMPLE,''))[0]\n        sub_len=data['N_token'].item()\n        try:\n            # ── RNAPro: inject RNet2 features before Protenix inference ────\n            sub_seq = seq_lookup.get(sname, '')\n            if sub_seq and len(sub_seq) == sub_len:\n                data = inject_rnet2_into_data(data, sub_seq)\n\n            new_cfg=update_inference_configs(cfg,sub_len)\n            new_cfg.sample_diffusion.N_sample=n_need\n            runner.update_model_configs(new_cfg)\n            pred=runner.predict(data)\n            raw_preds[sname]=extract_c1(pred,data['input_feature_dict'],sub_len)\n        except Exception as ex:\n            print(f'  {sname}: {ex}'); raw_preds[sname]=None\n        finally:\n            try: del pred,data,atom_array\n            except: pass\n            gc.collect(); torch.cuda.empty_cache()\n\n    # Stitch long-sequence chunks\n    for tid,(n_need,seq) in ptx_queue.items():\n        L=len(seq); cinfos=chunk_info.get(tid,[])\n        if not cinfos: continue\n        if len(cinfos)==1:\n            ptx_preds[tid]=raw_preds.get(tid)\n        else:\n            per=[[] for _ in range(n_need)]; ok=True\n            for ci in cinfos:\n                c=raw_preds.get(ci['name'])\n                if c is None: ok=False; break\n                for si in range(n_need): per[si].append((c[min(si,len(c)-1)],ci['range']))\n            if not ok: ptx_preds[tid]=None; continue\n            stitched=[stitch_chunks([c for c,_ in it],[r for _,r in it],L) for it in per]\n            ptx_preds[tid]=np.stack(stitched,0)\n            print(f'  {tid}: stitched {len(stitched)} predictions')\n\nelif ptx_queue and not PTX_DIR:\n    print('Phase 2 skipped: attach qiweiyin/protenix-v1-adjusted dataset')\nelif ptx_queue and not USE_PROTENIX:\n    print('Phase 2 skipped (USE_PROTENIX=False)')\nelse:\n    print('Phase 2: all targets covered by TBM.')\n","metadata":{"trusted":true},"outputs":[],"execution_count":null},{"cell_type":"code","source":"print(f\"\\n{'='*60}\")\nprint('PHASE 3 — Combine + Physics + Save')\nprint(f\"{'='*60}\")\n\nall_rows=[]\nfor _,row in test_df.iterrows():\n    tid=row['target_id']; seq=row['sequence']\n    segs=segs_map.get(tid,[(0,len(seq))])\n    combined=list(preds_map.get(tid,[]))\n\n    ptx=ptx_preds.get(tid)\n    if ptx is not None and ptx.ndim==3:\n        for j in range(ptx.shape[0]):\n            if len(combined)>=N_SAMPLE: break\n            combined.append(rna_physics(ptx[j],segs,confidence=0.85).astype(np.float32))\n\n    n_dn=0\n    while len(combined)<N_SAMPLE:\n        combined.append(rna_physics(denovo(seq,seed=hash(tid)+n_dn),segs,confidence=0.1).astype(np.float32))\n        n_dn+=1\n    if n_dn: print(f'  {tid}: {n_dn} de-novo')\n\n    stacked=np.stack(combined[:N_SAMPLE],0)\n    for i in range(len(seq)):\n        r={'ID':f'{tid}_{i+1}','resname':seq[i],'resid':i+1}\n        for k in range(N_SAMPLE):\n            r[f'x_{k+1}']=float(stacked[k,i,0])\n            r[f'y_{k+1}']=float(stacked[k,i,1])\n            r[f'z_{k+1}']=float(stacked[k,i,2])\n        all_rows.append(r)\n\ncols=['ID','resname','resid']+[f'{c}_{k}' for k in range(1,N_SAMPLE+1) for c in ['x','y','z']]\nsub=pd.DataFrame(all_rows)\ncc=[c for c in cols if c.startswith(('x_','y_','z_'))]\nsub[cc]=sub[cc].clip(-999.999,9999.999)\nsub[cols].to_csv(OUT_CSV,index=False)\n\nprint(f'\\n✓ {OUT_CSV}')\nprint(f'  Rows     : {len(sub):,}')\nprint(f'  Size     : {os.path.getsize(OUT_CSV)/1e6:.2f} MB')\nprint(f'  Targets  : {len(test_df)}')\nprint(f'  TBM full : {sum(1 for t in test_df.target_id if t not in ptx_queue)}')\nprint(f'  Protenix : {len(ptx_preds)}')\nprint(f'  Files    : {os.listdir(\"/kaggle/working\")}')\n","metadata":{"trusted":true},"outputs":[],"execution_count":null}]}