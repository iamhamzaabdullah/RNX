    "class RNet2Gate(nn.Module):\n",
    "    '''\n",
    "    RNAPro-style sigmoid gating: injects RNet2 features into Protenix streams.\n",
    "    gate = sigmoid(LayerNorm(rnet2_feat) @ W + b)\n",
    "    output = protenix_feat + gate * rnet2_feat\n",
    "    Init: bias=-2 → gate≈0.12, conservative injection preserving Protenix.\n",
    "    '''\n",
    "    def __init__(self,dim):\n",
    "        super().__init__()\n",
    "        self.gate=nn.Sequential(nn.LayerNorm(dim),nn.Linear(dim,dim,bias=True),nn.Sigmoid())\n",
    "        nn.init.zeros_(self.gate[1].weight)\n",
    "        nn.init.constant_(self.gate[1].bias,-2.0)\n",
    "    def forward(self,ptx_feat,rnet2_feat):\n",
    "        return ptx_feat+self.gate(rnet2_feat)*rnet2_feat\n",
    "\n",
    "single_gate=RNet2Gate(RNET2_NINP).to(device)\n",
    "pair_gate  =RNet2Gate(RNET2_PAIR_DIM).to(device)\n",
    "print(f'Gating modules: single={RNET2_NINP}d  pair={RNET2_PAIR_DIM}d')\n",
    "\n",
    "\n",
    "_NUC2ID={'A':0,'U':1,'G':2,'C':3,'T':1,'N':5}\n",
    "\n",
    "@torch.no_grad()\n",
    "def get_rnet2_features(seq_str):\n",
    "    'Run frozen RNet2; return final-layer single (L,384) and pair (L,L,128).'\n",
    "    tokens=torch.tensor([_NUC2ID.get(c.upper(),5) for c in seq_str],\n",
    "                         dtype=torch.long,device=device).unsqueeze(0)\n",
    "    mask=torch.ones(1,len(seq_str),dtype=torch.long,device=device)\n",
    "    torch.backends.cudnn.deterministic=False\n",
    "    s_feat,p_feat=rnet2.get_embeddings(tokens,src_mask=mask)\n",
    "    torch.backends.cudnn.deterministic=True\n",
    "    return s_feat.squeeze(0).float(), p_feat.squeeze(0).float()\n",
    "\n",
    "\n",
    "def inject_rnet2(data,seq_str):\n",
    "    '''\n",
    "    RNAPro injection: add RNet2 single+pair embeddings to Protenix\n",
    "    input_feature_dict via learned sigmoid gating.\n",
    "    Silently skips on any error so Protenix always runs.\n",
    "    '''\n",
    "    try:\n",
    "        slen=len(seq_str)\n",
    "        rn_s,rn_p=get_rnet2_features(seq_str)   # (L,384), (L,L,128)\n",
    "        feat=data['input_feature_dict']\n",
    "        # Single stream\n",
    "        for key in ('single','target_feat'):\n",
    "            if key in feat:\n",
    "                f=feat[key].float().to(device)\n",
    "                if f.dim()==2 and f.shape[0]==slen and f.shape[1]==RNET2_NINP:\n",
    "                    feat[key]=single_gate(f,rn_s).to(feat[key].dtype); break\n",
    "        # Pair stream\n",
    "        for key in ('pair','pair_feat'):\n",
    "            if key in feat:\n",
    "                f=feat[key].float().to(device)\n",
    "                if f.dim()==3 and f.shape[0]==slen and f.shape[2]==RNET2_PAIR_DIM:\n",
    "                    feat[key]=pair_gate(f,rn_p).to(feat[key].dtype); break\n",
    "    except Exception:\n",
    "        pass  # Protenix runs unmodified on any failure\n",
    "    return data\n",
    "\n",
    "print('RNet2 injection pipeline ready.')\n"
   ]
