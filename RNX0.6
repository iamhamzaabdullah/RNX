    "NUC_MAP = {\n",
    "    'A':0,'U':1,'G':2,'C':3,'T':1,'N':4,\n",
    "    'I':0,'PSU':1,'M2G':2,'5MC':3,'M7G':2,'H2U':1,'5MU':1,'4SU':1,'2MU':1,\n",
    "    '1MA':0,'2MA':0,'6MA':0,'1MG':2,'2MG':2,'OMC':3,'OMG':2,'OMU':1,'DHU':1,\n",
    "    'M5C':3,'M1A':0,'M1G':2,'M3C':3,'M5U':1,'M6A':0,'GTP':2,'ATP':0,'UTP':1,'CTP':3,\n",
    "}\n",
    "\n",
    "def parse_cif(path):\n",
    "    chains=defaultdict(list)\n",
    "    try:\n",
    "        with open(path,errors='replace') as fh: lines=fh.readlines()\n",
    "        col,ci,in_a={},0,False\n",
    "        need={'group_PDB','label_atom_id','label_comp_id',\n",
    "              'label_asym_id','label_seq_id','Cartn_x','Cartn_y','Cartn_z'}\n",
    "        for line in lines:\n",
    "            s=line.strip()\n",
    "            if s=='loop_': col,ci,in_a={},0,False; continue\n",
    "            if s.startswith('_atom_site.'):\n",
    "                col[s.split('.',1)[1].split()[0]]=ci; ci+=1; in_a=True; continue\n",
    "            if in_a and s and not s.startswith(('_','#','loop_','data_')):\n",
    "                if not need.issubset(col): continue\n",
    "                p=s.split()\n",
    "                if len(p)<=max(col.values()): continue\n",
    "                if p[col['group_PDB']] not in ('ATOM','HETATM'): continue\n",
    "                if p[col['label_atom_id']].strip('\"')!=\"C1'\": continue\n",
    "                rn=p[col['label_comp_id']]; ch=p[col['label_asym_id']]\n",
    "                try: rs=int(p[col['label_seq_id']])\n",
    "                except: continue\n",
    "                try: x,y,z=float(p[col['Cartn_x']]),float(p[col['Cartn_y']]),float(p[col['Cartn_z']])\n",
    "                except: continue\n",
    "                can=None\n",
    "                if rn in NUC_MAP: nc=NUC_MAP[rn]; can='AUGCN'[nc] if nc<4 else None\n",
    "                elif len(rn)==1 and rn in 'AUGCT': can='U' if rn=='T' else rn\n",
    "                if can: chains[ch].append((can,rs,x,y,z))\n",
    "    except: pass\n",
    "    for ch in chains: chains[ch].sort(key=lambda r:r[1])\n",
    "    return dict(chains)\n",
    "\n",
    "class CIFTemplateDB:\n",
    "    def __init__(self,cif_dir,max_len=1000):\n",
    "        self.entries=[]; self.kidx=defaultdict(list)\n",
    "        if not os.path.isdir(cif_dir): print('CIF dir not found'); return\n",
    "        cifs=sorted(f for f in os.listdir(cif_dir) if f.endswith('.cif'))\n",
    "        print(f'Indexing {len(cifs)} CIF files...')\n",
    "        t0=time.time(); n=0\n",
    "        for fname in cifs:\n",
    "            pid=Path(fname).stem\n",
    "            for ch,data in parse_cif(os.path.join(cif_dir,fname)).items():\n",
    "                if not (10<=len(data)<=max_len): continue\n",
    "                seq=''.join(r[0] for r in data)\n",
    "                coords=np.array([[r[2],r[3],r[4]] for r in data],np.float32)\n",
    "                if len(seq)!=len(coords): continue\n",
    "                idx=len(self.entries)\n",
    "                self.entries.append((seq,coords,f'{pid}_{ch}'))\n",
    "                for i in range(0,len(seq)-7,3): self.kidx[seq[i:i+8]].append(idx)\n",
    "                n+=1\n",
    "        print(f'  {n} chains indexed in {time.time()-t0:.1f}s')\n",
    "    def __len__(self): return len(self.entries)\n",
    "    def candidates(self,query,top_k=20):\n",
    "        if not self.entries: return []\n",
    "        votes=defaultdict(int)\n",
    "        for i in range(0,len(query)-7,2):\n",
    "            for idx in self.kidx.get(query[i:i+8],[])[:50]: votes[idx]+=1\n",
    "        if not votes:\n",
    "            return [self.entries[i] for i in random.sample(range(len(self.entries)),min(top_k,len(self.entries)))]\n",
    "        out,seen=[],[]\n",
    "        for idx in sorted(votes,key=lambda x:-votes[x]):\n",
    "            s,c,lb=self.entries[idx]; root=lb.split('_')[0]\n",
    "            if root in seen: continue\n",
    "            seen.append(root); out.append((s,c,lb))\n",
    "            if len(out)>=top_k: break\n",
    "        return out\n",
    "\n",
    "print('Building CIF DB...')\n",
    "cif_db=CIFTemplateDB(PDB_RNA)\n",
    "print(f'CIFTemplateDB: {len(cif_db)} entries')\n"
   ]
  },
