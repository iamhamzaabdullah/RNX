    "import subprocess, os, sys, glob\n",
    "\n",
    "def install_wheel(pkg, patterns, fallback_pip=True):\n",
    "    for pat in patterns:\n",
    "        hits = glob.glob(pat)\n",
    "        if hits:\n",
    "            r = subprocess.run(\n",
    "                ['pip','install','--no-index','--no-deps','--quiet', hits[0]],\n",
    "                capture_output=True, text=True)\n",
    "            if r.returncode == 0:\n",
    "                print(f'  {pkg}: installed from wheel')\n",
    "                return True\n",
    "            print(f'  {pkg}: wheel failed ({r.stderr[:60]})')\n",
    "    if fallback_pip:\n",
    "        r = subprocess.run(['pip','install','--quiet', pkg],\n",
    "                           capture_output=True, text=True)\n",
    "        if r.returncode == 0:\n",
    "            print(f'  {pkg}: installed via pip')\n",
    "            return True\n",
    "    print(f'  {pkg}: INSTALL FAILED')\n",
    "    return False\n",
    "\n",
    "install_wheel('biopython', [\n",
    "    '/kaggle/input/biopython-cp312/*.whl',\n",
