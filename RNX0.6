   "source": [
    "_aln = PairwiseAligner()\n",
    "_aln.mode                          = 'global'\n",
    "_aln.match_score                   = 2\n",
    "_aln.mismatch_score                = -1.5\n",
    "_aln.open_gap_score                = -8\n",
    "_aln.extend_gap_score              = -0.4\n",
    "_aln.query_left_open_gap_score     = -8\n",
    "_aln.query_left_extend_gap_score   = -0.4\n",
    "_aln.query_right_open_gap_score    = -8\n",
    "_aln.query_right_extend_gap_score  = -0.4\n",
    "_aln.target_left_open_gap_score    = -8\n",
    "_aln.target_left_extend_gap_score  = -0.4\n",
    "_aln.target_right_open_gap_score   = -8\n",
    "_aln.target_right_extend_gap_score = -0.4\n",
    "\n",
    "def align_score(q, t):\n",
    "    aln   = next(iter(_aln.align(q, t)))\n",
    "    norm  = aln.score / (2 * min(len(q), len(t)))\n",
    "    ident = sum(1 for (qs,qe),(ts,te) in zip(*aln.aligned)\n",
    "                for qp,tp in zip(range(qs,qe),range(ts,te)) if q[qp]==t[tp])\n",
    "    return aln, norm, 100*ident/max(len(q),1)\n",
    "\n",
    "def adapt_coords(q, t, tc):\n",
    "    'Align template to query and map coordinates; interpolate gaps.'\n",
    "    aln = next(iter(_aln.align(q, t)))\n",
    "    out = np.full((len(q),3), np.nan, np.float32)\n",
    "    for (qs,qe),(ts,te) in zip(*aln.aligned):\n",
    "        chunk = tc[ts:te]\n",
    "        if len(chunk) == qe-qs:\n",
    "            out[qs:qe] = chunk\n",
    "    _fill_gaps(out)\n",
    "    return np.nan_to_num(out, nan=0.0)\n",
    "\n",
    "def _fill_gaps(c):\n",
    "    n=len(c); v=[i for i in range(n) if not np.isnan(c[i,0])]\n",
    "    if not v: return\n",
    "    for i in range(v[0]-1,-1,-1): c[i]=c[v[0]]+np.array([3,0,0],np.float32)*(v[0]-i)\n",
    "    for i in range(v[-1]+1,n):    c[i]=c[v[-1]]+np.array([3,0,0],np.float32)*(i-v[-1])\n",
    "    for k in range(len(v)-1):\n",
    "        a,b=v[k],v[k+1]\n",
    "        for i in range(a+1,b):\n",
    "            w=(i-a)/(b-a); c[i]=(1-w)*c[a]+w*c[b]\n",
    "\n",
    "print('Aligner ready.')\n"
   ]
  },
