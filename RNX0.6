    "# ════════════════════════════════════════════════════════════════\n",
    "# SELF-SCORING — TM-align approximation on validation set\n",
    "#\n",
    "# Uses validation labels (which we have) to estimate LB score.\n",
    "# Implements the exact TM-score formula from the competition:\n",
    "#   TM = (1/L_ref) * sum_i  1 / (1 + (d_i/d0)^2)\n",
    "# where d0 = 0.6*(L_ref-0.5)^0.5 - 2.5  for L_ref >= 30\n",
    "# Score > 0.45 = correct global fold.\n",
    "# ════════════════════════════════════════════════════════════════\n",
    "\n",
    "def d0_rna(L):\n",
    "    if L >= 30: return 0.6*(L-0.5)**0.5 - 2.5\n",
    "    if L < 12:  return 0.3\n",
    "    if L < 16:  return 0.4\n",
    "    if L < 20:  return 0.5\n",
    "    if L < 24:  return 0.6\n",
    "    return 0.7\n",
    "\n",
    "\n",
    "def tm_align_score(pred_coords, ref_coords):\n",
    "    '''\n",
    "    Compute TM-align score between predicted and reference C1' coords.\n",
    "    Tries all N_SAMPLE predictions, returns best score.\n",
    "    pred_coords: (N_SAMPLE, L, 3) or (L, 3)\n",
    "    ref_coords : (L, 3)\n",
    "    '''\n",
    "    if pred_coords.ndim == 2:\n",
    "        pred_coords = pred_coords[np.newaxis]\n",
    "    L_ref = len(ref_coords)\n",
    "    d0    = d0_rna(L_ref)\n",
    "    best  = 0.0\n",
    "    for pred in pred_coords:\n",
    "        L_al = min(len(pred), L_ref)\n",
    "        p = pred[:L_al]; r = ref_coords[:L_al]\n",
    "        # Kabsch superposition\n",
    "        try:\n",
    "            R, t = kabsch(p, r)\n",
    "            p_rot = p @ R.T + t\n",
    "        except Exception:\n",
    "            p_rot = p\n",
    "        d = np.linalg.norm(p_rot - r, axis=1)      # (L_al,)\n",
    "        score = float(np.sum(1.0/(1.0+(d/d0)**2)) / L_ref)\n",
    "        if score > best: best = score\n",
    "    return best\n",
    "\n",
    "\n",
    "print(f\"\\n{'='*60}\")\n",
    "print('SELF-SCORING — Validation set TM-align estimate')\n",
    "print(f\"{'='*60}\")\n",
    "\n",
    "# Build ground-truth dict from validation labels\n",
    "# (We use val only — not test, since we don't have test labels)\n",
    "val_gt = process_labels(pd.read_csv(VAL_LBL))\n",
    "val_ids = set(pd.read_csv(VAL_CSV)['target_id'])\n",
    "\n",
    "# Also check train labels for any overlap with test targets\n",
    "# (For genuine self-test, only evaluate on val targets)\n",
    "sub_indexed = sub.set_index('ID')\n",
    "\n",
    "scores = []\n",
    "correct_folds = 0\n",
    "results_table = []\n",
    "\n",
    "for tid in val_ids:\n",
    "    if tid not in val_gt: continue\n",
    "    ref = val_gt[tid]  # (L, 3)\n",
    "    L   = len(ref)\n",
    "\n",
    "    # Reconstruct our predictions for this target\n",
    "    rows_for_tid = []\n",
    "    for ri in range(1, L+1):\n",
    "        row_id = f'{tid}_{ri}'\n",
    "        if row_id not in sub_indexed.index: break\n",
    "        rows_for_tid.append(sub_indexed.loc[row_id])\n",
    "\n",
    "    if len(rows_for_tid) != L: continue\n",
    "\n",
    "    pred_all = np.zeros((N_SAMPLE, L, 3), np.float32)\n",
    "    for k in range(N_SAMPLE):\n",
    "        for ri, r in enumerate(rows_for_tid):\n",
    "            pred_all[k, ri, 0] = float(r[f'x_{k+1}'])\n",
    "            pred_all[k, ri, 1] = float(r[f'y_{k+1}'])\n",
    "            pred_all[k, ri, 2] = float(r[f'z_{k+1}'])\n",
    "\n",
    "    tm = tm_align_score(pred_all, ref)\n",
    "    scores.append(tm)\n",
    "    if tm > 0.45: correct_folds += 1\n",
    "    results_table.append({'target': tid, 'L': L, 'TM-align': round(tm,4),\n",
    "                          'correct_fold': tm>0.45})\n",
    "\n",
    "if scores:\n",
    "    results_df = pd.DataFrame(results_table).sort_values('TM-align', ascending=False)\n",
    "    mean_tm    = np.mean(scores)\n",
    "    median_tm  = np.median(scores)\n",
    "    pct_correct= 100*correct_folds/len(scores)\n",
    "\n",
    "    print(f'\\nValidation targets scored : {len(scores)}')\n",
    "    print(f'Mean TM-align             : {mean_tm:.4f}  (LB proxy)')\n",
    "    print(f'Median TM-align           : {median_tm:.4f}')\n",
    "    print(f'Correct folds (>0.45)     : {correct_folds}/{len(scores)} ({pct_correct:.1f}%)')\n",
    "    print(f'\\nLeaderboard estimate      : ~{mean_tm:.3f}')\n",
    "    print(f'  (Val set is harder than future-PDB targets')\n",
    "    print(f'   so actual LB is likely {mean_tm+0.05:.3f}–{mean_tm+0.12:.3f})')\n",
    "\n",
    "    print(f'\\n--- Top 10 predictions ---')\n",
    "    print(results_df.head(10).to_string(index=False))\n",
    "    print(f'\\n--- Bottom 5 predictions ---')\n",
    "    print(results_df.tail(5).to_string(index=False))\n",
    "\n",
    "    # Save scoring report\n",
    "    results_df.to_csv('/kaggle/working/self_score_report.csv', index=False)\n",
    "    print(f'\\nFull report saved: /kaggle/working/self_score_report.csv')\n",
    "else:\n",
    "    print('No validation targets found in submission — check target IDs.')\n",
    "    print('This is expected if all val targets scored TBM 5/5.')\n",
    "\n",
    "print(f\"\\n{'='*60}\")\n",
    "print('RNX 0.7 complete.')\n",
    "print(f\"{'='*60}\")\n"
   ]
