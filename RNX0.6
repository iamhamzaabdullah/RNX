    "def process_labels(df):\n",
    "    coords={}\n",
    "    pfx=df['ID'].str.rsplit('_',n=1).str[0]\n",
    "    for p,g in df.groupby(pfx):\n",
    "        coords[p]=g.sort_values('resid')[['x_1','y_1','z_1']].values.astype(np.float32)\n",
    "    return coords\n",
    "\n",
    "def get_chain_segs(row):\n",
    "    seq=row['sequence']; stoich=row.get('stoichiometry',''); allsq=row.get('all_sequences','')\n",
    "    if pd.isna(stoich) or pd.isna(allsq) or not str(stoich).strip(): return [(0,len(seq))]\n",
    "    try:\n",
    "        fasta={}; cur=None; parts=[]\n",
    "        for line in str(allsq).splitlines():\n",
    "            line=line.strip()\n",
    "            if line.startswith('>'):\n",
    "                if cur: fasta[cur]=''.join(parts)\n",
    "                cur=line[1:].split()[0]; parts=[]\n",
    "            elif line: parts.append(line)\n",
    "        if cur: fasta[cur]=''.join(parts)\n",
    "        order=[(ch.strip(),int(cnt)) for part in str(stoich).split(';')\n",
    "               for ch,cnt in [part.split(':')]]\n",
    "        segs=[]; pos=0\n",
    "        for ch,cnt in order:\n",
    "            b=fasta.get(ch)\n",
    "            if b is None: return [(0,len(seq))]\n",
    "            for _ in range(cnt): segs.append((pos,pos+len(b))); pos+=len(b)\n",
    "        return segs if pos==len(seq) else [(0,len(seq))]\n",
    "    except: return [(0,len(seq))]\n",
    "\n",
    "print('Loading train+val data...')\n",
    "train_seqs   = pd.read_csv(TRAIN_CSV)\n",
    "val_seqs     = pd.read_csv(VAL_CSV)\n",
    "all_seqs     = pd.concat([train_seqs,val_seqs],ignore_index=True)\n",
    "train_labels = pd.read_csv(TRAIN_LBL)\n",
    "val_labels   = pd.read_csv(VAL_LBL)\n",
    "all_coords   = process_labels(pd.concat([train_labels,val_labels],ignore_index=True))\n",
    "print(f'  {len(all_seqs)} sequences, {len(all_coords)} structures')\n",
    "\n",
    "# Length-bucket index for fast pre-filtering (avoids aligning wildly different lengths)\n",
    "len_buckets = defaultdict(list)  # bucket -> list of (tid, seq)\n",
    "for _,row in all_seqs.iterrows():\n",
    "    tid=row['target_id']\n",
    "    if tid not in all_coords: continue\n",
    "    seq=row['sequence']\n",
    "    bucket=len(seq)//50  # group by 50-nt windows\n",
    "    len_buckets[bucket].append((tid,seq))\n",
    "print(f'  Length buckets: {len(len_buckets)}')\n",
    "\n",
    "test_df=pd.read_csv(TEST_CSV)\n",
    "if not IS_KAGGLE and LOCAL_N: test_df=test_df.head(LOCAL_N)\n",
    "test_df=test_df.reset_index(drop=True)\n",
    "segs_map={r['target_id']:get_chain_segs(r) for _,r in test_df.iterrows()}\n",
    "print(f'  {len(test_df)} test targets')\n"
   ]
