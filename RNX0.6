    "def weighted_blend(coord_list,weights):\n",
    "    w=np.array(weights,np.float64); w/=w.sum()\n",
    "    return sum(c*wi for c,wi in zip(coord_list,w)).astype(np.float32)\n",
    "\n",
    "def gather_candidates(query):\n",
    "    '''\n",
    "    Dual-source template search with length pre-filter for speed.\n",
    "    Source A: train/val label structures (exact coordinates)\n",
    "    Source B: PDB_RNA CIF chains (structural homologs)\n",
    "    '''\n",
    "    cands=[]\n",
    "    qlen=len(query)\n",
    "\n",
    "    # Source A: competition structures — search nearby length buckets only\n",
    "    q_bucket=qlen//50\n",
    "    search_buckets=set(range(max(0,q_bucket-2), q_bucket+3))  # ±100nt window\n",
    "    for bucket in search_buckets:\n",
    "        for tid,tseq in len_buckets.get(bucket,[]):\n",
    "            if abs(len(tseq)-qlen)/max(len(tseq),qlen)>0.4: continue\n",
    "            try:\n",
    "                _,norm,pct=align_score(query,tseq)\n",
    "                if norm>=MIN_SIM and pct>=MIN_PCT_ID:\n",
    "                    cands.append((norm,pct,adapt_coords(query,tseq,all_coords[tid]),tid))\n",
    "            except: pass\n",
    "\n",
    "    # Source B: CIF structural DB (catches homologs outside training set)\n",
    "    for tseq,tc,label in cif_db.candidates(query,top_k=20):\n",
    "        if abs(len(tseq)-qlen)/max(len(tseq),qlen)>0.5: continue\n",
    "        try:\n",
    "            _,norm,pct=align_score(query,tseq)\n",
    "            if norm>=MIN_SIM and pct>=MIN_PCT_ID*0.7:\n",
    "                cands.append((norm*0.9,pct,adapt_coords(query,tseq,tc),label))\n",
    "        except: pass\n",
    "\n",
    "    cands.sort(key=lambda x:-x[0])\n",
    "    return cands[:TOP_N]\n",
    "\n",
    "\n",
    "def tbm_phase(test_df):\n",
    "    print(f\"\\n{'='*60}\")\n",
    "    print('PHASE 1 — Dual-Source TBM')\n",
    "    print(f'  SourceA:{len(all_seqs)} train/val | SourceB:{len(cif_db)} CIF')\n",
    "    print(f\"{'='*60}\")\n",
    "    t0=time.time(); preds_map={}; ptx_queue={}\n",
    "    for _,row in test_df.iterrows():\n",
    "        tid=row['target_id']; seq=row['sequence']\n",
    "        segs=segs_map.get(tid,[(0,len(seq))])\n",
    "        cands=gather_candidates(seq)\n",
    "        preds=[]; used=set()\n",
    "        for i,(norm,pct,adapted,label) in enumerate(cands):\n",
    "            if len(preds)>=N_SAMPLE: break\n",
    "            if label in used: continue\n",
    "            used.add(label)\n",
    "            rng=np.random.default_rng((hash(tid)+i*10007)%(2**32))\n",
    "            slot=len(preds)\n",
    "            if slot==0:\n",
    "                X=weighted_blend([c[2] for c in cands[:BLEND_K]],\n",
    "                                  [c[0] for c in cands[:BLEND_K]]) if len(cands)>=BLEND_K else adapted\n",
    "            elif slot==1: X=adapted+rng.normal(0,max(0.01,(0.40-norm)*0.06),adapted.shape)\n",
    "            elif slot==2: X=apply_hinge(adapted,max(segs,key=lambda s:s[1]-s[0]),rng)\n",
    "            elif slot==3: X=jitter(adapted,segs,rng)\n",
    "            else:         X=wiggle(adapted,segs,rng)\n",
    "            preds.append(rna_physics(X,segs,confidence=norm).astype(np.float32))\n",
    "        preds_map[tid]=preds\n",
    "        n_need=N_SAMPLE-len(preds)\n",
    "        status=f'{len(preds)} TBM + {n_need}→Protenix' if n_need>0 else '5/5 TBM'\n",
    "        if n_need>0: ptx_queue[tid]=(n_need,seq)\n",
    "        print(f'  {tid} L={len(seq)}: {status}')\n",
    "    print(f'Phase 1: {time.time()-t0:.1f}s | TBM-full:{len(test_df)-len(ptx_queue)} | Queue:{len(ptx_queue)}')\n",
    "    return preds_map,ptx_queue\n",
    "\n",
    "preds_map,ptx_queue=tbm_phase(test_df)\n"
   ]
