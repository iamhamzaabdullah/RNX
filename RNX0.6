    "def kabsch(P,Q):\n",
    "    cp,cq=P.mean(0),Q.mean(0); Pc,Qc=P-cp,Q-cq\n",
    "    U,_,Vt=np.linalg.svd(Pc.T@Qc); d=np.linalg.det(Vt.T@U.T)\n",
    "    S=np.diag([1,1,d]); R=Vt.T@S@U.T\n",
    "    return R,cq-R@cp\n",
    "\n",
    "def stitch_chunks(chunk_list,ranges,seq_len):\n",
    "    if len(chunk_list)==1:\n",
    "        out=np.zeros((seq_len,3),chunk_list[0].dtype)\n",
    "        out[:min(len(chunk_list[0]),seq_len)]=chunk_list[0][:seq_len]; return out\n",
    "    aligned=[chunk_list[0].copy()]\n",
    "    for i in range(1,len(chunk_list)):\n",
    "        ps,pe=ranges[i-1]; cs,ce=ranges[i]\n",
    "        ov_s,ov_e=cs,min(pe,ce)\n",
    "        if ov_e-ov_s<3: aligned.append(chunk_list[i].copy()); continue\n",
    "        pov=aligned[i-1][ov_s-ps:ov_e-ps]; cov=chunk_list[i][ov_s-cs:ov_e-cs]\n",
    "        valid=~(np.isnan(pov).any(1)|np.isnan(cov).any(1))\n",
    "        if valid.sum()<3: aligned.append(chunk_list[i].copy()); continue\n",
    "        R,t=kabsch(cov[valid],pov[valid]); aligned.append((chunk_list[i]@R.T)+t)\n",
    "    full=np.zeros((seq_len,3),np.float64); wt=np.zeros(seq_len)\n",
    "    for i,((s,e),c) in enumerate(zip(ranges,aligned)):\n",
    "        ae=min(s+len(c),seq_len); ul=ae-s; w=np.ones(ul)\n",
    "        if i>0:\n",
    "            rl=min(ranges[i-1][1],e)-s\n",
    "            if rl>0: w[:rl]=np.linspace(0,1,rl)\n",
    "        if i<len(ranges)-1:\n",
    "            ns=ranges[i+1][0]; rs2=ns-s; rl=ae-ns\n",
    "            if rl>0 and rs2<ul: w[rs2:ul]=np.linspace(1,0,rl)\n",
    "        full[s:ae]+=c[:ul]*w[:,None]; wt[s:ae]+=w\n",
    "    mask=wt>0; full[mask]/=wt[mask,None]\n",
    "    return full.astype(np.float32)\n",
    "\n",
    "def rna_physics(X,segs,confidence=1.0,passes=CONSTRAINT_PASS):\n",
    "    X=X.copy(); st=max(0.75*(1.0-min(confidence,0.97)),0.02)\n",
    "    for _ in range(passes):\n",
    "        for s,e in segs:\n",
    "            C=X[s:e]; L=e-s\n",
    "            if L<3: continue\n",
    "            d=C[1:]-C[:-1]; dn=np.linalg.norm(d,axis=1)+1e-6\n",
    "            adj=d*((5.95-dn)/dn)[:,None]*0.22*st; C[:-1]-=adj; C[1:]+=adj\n",
    "            d2=C[2:]-C[:-2]; d2n=np.linalg.norm(d2,axis=1)+1e-6\n",
    "            adj2=d2*((10.2-d2n)/d2n)[:,None]*0.10*st; C[:-2]-=adj2; C[2:]+=adj2\n",
    "            C[1:-1]+=0.06*st*(0.5*(C[:-2]+C[2:])-C[1:-1])\n",
    "            if L>=25:\n",
    "                idx=np.linspace(0,L-1,min(L,160)).astype(int) if L>220 else np.arange(L)\n",
    "                P2=C[idx]; dif=P2[:,None,:]-P2[None,:,:]\n",
    "                dm=np.linalg.norm(dif,axis=2)+1e-6\n",
    "                sp=np.abs(idx[:,None]-idx[None,:]); mk=(sp>2)&(dm<3.2)\n",
    "                if np.any(mk):\n",
    "                    vec=(dif*((3.2-dm)/dm)[:,:,None]*mk[:,:,None]).sum(1)\n",
    "                    C[idx]+=0.015*st*vec\n",
    "            X[s:e]=C\n",
    "    return X\n",
    "\n",
    "def _rot(ax,ang):\n",
    "    a=np.asarray(ax,float); a/=np.linalg.norm(a)+1e-12; x,y,z=a\n",
    "    c,s=np.cos(ang),np.sin(ang); CC=1-c\n",
    "    return np.array([[c+x*x*CC,x*y*CC-z*s,x*z*CC+y*s],\n",
    "                     [y*x*CC+z*s,c+y*y*CC,y*z*CC-x*s],\n",
    "                     [z*x*CC-y*s,z*y*CC+x*s,c+z*z*CC]])\n",
    "def apply_hinge(X,seg,rng,deg=22):\n",
    "    s,e=seg; L=e-s\n",
    "    if L<30: return X\n",
    "    pv=s+int(rng.integers(10,L-10))\n",
    "    R=_rot(rng.normal(size=3),np.deg2rad(float(rng.uniform(-deg,deg))))\n",
    "    Y=X.copy(); p0=Y[pv].copy(); Y[pv+1:e]=(Y[pv+1:e]-p0)@R.T+p0; return Y\n",
    "def jitter(X,segs,rng,deg=12,tr=1.5):\n",
    "    Y=X.copy(); gc=Y.mean(0,keepdims=True)\n",
    "    for s,e in segs:\n",
    "        R=_rot(rng.normal(size=3),np.deg2rad(float(rng.uniform(-deg,deg))))\n",
    "        sh=rng.normal(size=3); sh=sh/(np.linalg.norm(sh)+1e-12)*float(rng.uniform(0,tr))\n",
    "        c=Y[s:e].mean(0,keepdims=True); Y[s:e]=(Y[s:e]-c)@R.T+c+sh\n",
    "    Y-=Y.mean(0,keepdims=True)-gc; return Y\n",
    "def wiggle(X,segs,rng,amp=0.8):\n",
    "    Y=X.copy()\n",
    "    for s,e in segs:\n",
    "        L=e-s\n",
    "        if L<20: continue\n",
    "        ctrl=np.linspace(0,L-1,6); d=rng.normal(0,amp,(6,3)); t=np.arange(L)\n",
    "        Y[s:e]+=np.vstack([np.interp(t,ctrl,d[:,k]) for k in range(3)]).T\n",
    "    return Y\n",
    "def denovo(seq,seed=0):\n",
    "    np.random.seed(seed%2**31); n=len(seq); c=np.zeros((n,3))\n",
    "    for i in range(n): c[i]=[10*np.cos(i*0.6),10*np.sin(i*0.6),i*2.5]\n",
    "    return c\n",
    "\n",
    "print('Geometry helpers ready.')\n"
   ]
  },
